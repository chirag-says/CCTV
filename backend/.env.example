# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinelai
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Vision Pipeline Configuration
DETECTION_MODEL=hog
FACE_MATCH_TOLERANCE=0.45
FRAME_SKIP=3
DETECTION_SCALE=0.5
EXIT_THRESHOLD_SECONDS=300
ENTRY_THRESHOLD_SECONDS=3
UNKNOWN_SIMILARITY_THRESHOLD=0.4

# Camera Configuration
DEFAULT_CAMERA_SOURCE=0
MAX_CAMERAS=10

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Storage
SNAPSHOT_DIR=./snapshots
MAX_SNAPSHOT_SIZE_KB=200

# Safety & Security Modules
ENABLE_ATTRIBUTE_RECOGNITION=true
ENABLE_CROWD_DETECTION=true
CROWD_PROXIMITY_PX=150
CROWD_MIN_PERSONS=3
CROWD_SUSTAIN_SECONDS=5.0
ENABLE_LOITERING_DETECTION=true
LOITER_MOVEMENT_THRESHOLD_PX=50
LOITER_TIME_WINDOW_SEC=300
LOITER_ALERT_COOLDOWN_SEC=600
ENABLE_HAZARD_DETECTION=true
HAZARD_MODEL_PATH=yolov8n.pt
HAZARD_FRAME_INTERVAL=30
HAZARD_ALERT_COOLDOWN_SEC=30

# Pipeline Mode: "face" (default), "traffic", or "hybrid"
PIPELINE_MODE=face

# Traffic Mode: ANPR (License Plate Recognition)
ENABLE_ANPR=true
ANPR_MODEL_PATH=yolov8n.pt
ANPR_FRAME_INTERVAL=5
ANPR_PLATE_COOLDOWN_SEC=60
ANPR_OCR_LANGUAGES=en

# Traffic Mode: Vehicle-Person Safety Monitor
ENABLE_TRAFFIC_MONITOR=true
TRAFFIC_MODEL_PATH=yolov8n.pt
TRAFFIC_FRAME_INTERVAL=5
TRAFFIC_PROXIMITY_PX=50
TRAFFIC_ALERT_COOLDOWN_SEC=15
